# ------------------------------------------------------------------
# In2Peta backend environment
# Copy to .env and fill in values. Everything has a safe local default
# except the secrets marked (required in production).
# ------------------------------------------------------------------

# --- Database ---
# Local dev (SQLite, zero setup — embeddings stored as JSON):
DATABASE_URL=sqlite+aiosqlite:///./in2peta.db
# Production (Neon Postgres with pgvector — note the +asyncpg driver):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/neondb?ssl=require

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Google OAuth (optional; login/register with email works without it) ---
# Create OAuth client at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {BACKEND_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- URLs ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# --- LLM provider ---
# "groq" | "gemini" | "openrouter" | "mock"
LLM_PROVIDER=gemini
# Set MOCK_LLM=true to force the mock provider (full demo without any API key)
MOCK_LLM=false
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
# Same key as embeddings. Model used for course + quiz + chat when LLM_PROVIDER=gemini.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
EMBEDDING_MODEL=gemini-embedding-001
# Keep 384 to match the existing chunks.embedding column / pgvector schema.
# EMBEDDING_DIM=384
# Set MOCK_EMBEDDINGS=true for offline demos (deterministic pseudo-vectors).
MOCK_EMBEDDINGS=false

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_PDF_MB=15
MAX_PDF_PAGES=300

# --- Generation ---
LESSON_CONCURRENCY=3
